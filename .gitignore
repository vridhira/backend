###############################################################################
# Vridhira Marketplace — Backend .gitignore
# MedusaJS v2 · Node.js · TypeScript
###############################################################################

# ── Secrets & Environment Variables ──────────────────────────────────────────
# NEVER commit real credentials. Use .env.template for placeholder reference.
.env
.env.local
.env.production
.env.staging
.env.*.local

# Runtime search provider config — environment-specific, not a secret but
# must not be shared across environments.
.search-config.json

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log
.pnp.*

# ── TypeScript build output ───────────────────────────────────────────────────
dist/
build/
.medusa/
*.js.map
*.d.ts.map
tsconfig.tsbuildinfo
./tsconfig.tsbuildinfo

# TypeScript diagnostic exports — generated manually for debugging, not source
tsc-errors.txt
tsc-out.txttsc-out-new.txt

# ── Internal dev / audit docs — not needed in production or public repo ───────
# These contain internal security analysis, bug tracking, and build notes.
# Production deployments should not expose vulnerability data or internal docs.
BUGS.md
SECURITY_ANALYSIS.md
security-audit.md
.eslintrc-security.js
.secretlintrc*
.secretlintignore

# Internal documentation and build logs
docs/
build-log-*.md
check-before-development.md
walkthrough.md
context-*.md

# CI security scan output directory
.security/
# ── Medusa-specific ───────────────────────────────────────────────────────────
uploads/
medusa-db.sql

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*

# ── Coverage & test output ────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Caches ────────────────────────────────────────────────────────────────────
.cache/
.turbo/
.parcel-cache/

# ── Yarn (keep plugin/patch/release metadata, ignore the rest) ───────────────
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Editor & IDE ──────────────────────────────────────────────────────────────
.idea/
.vscode/*
# Allow shared editor settings (formatting rules, extension recommendations)
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
*.swp
*.swo
*~

# ── Local data (Meilisearch Docker volume, etc.) ─────────────────────────────
meili_data/
data.ms/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.pem
*.key
