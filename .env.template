STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=
DB_NAME=medusa-v2
# ── Razorpay ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_ACCOUNT=

# ── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@vridhira.in

# ── Shiprocket ──────────────────────────────────────────────────────────────
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_WEBHOOK_TOKEN=
# Your warehouse pincode — used for serviceability checks and rate calculation
# e.g. 400001 for Mumbai, 110001 for Delhi
SHIPROCKET_PICKUP_POSTCODE=
# Exact name of the pickup address as configured in Shiprocket Dashboard
# Admin › Manage › Pickup Addresses — must match exactly or API calls will fail
SHIPROCKET_PICKUP_LOCATION=

# ── Medusa Stock Location ────────────────────────────────────────────────────
# Required by createOrderFulfillmentWorkflow to link fulfillments to inventory
# Step 1: Admin › Settings › Locations › create a location (e.g. "Warehouse")
# Step 2: Copy the location ID from the URL or API and paste it here
MEDUSA_STOCK_LOCATION_ID=

# ── Twilio (COD OTP) ────────────────────────────────────────────────────────
# Create a free trial at https://www.twilio.com — or use a verified Indian sender
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 format number verified in your Twilio account, e.g. +918888888888
TWILIO_FROM_PHONE=

# ── Google OAuth (Social Login) ─────────────────────────────────────────────
# 1. https://console.cloud.google.com → Create/select project
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Set Authorised redirect URI to your storefront callback page URL:
#    dev:  http://localhost:8000/auth/google/callback
#    prod: https://vridhira.in/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# The storefront page Medusa redirects to after Google auth (must match above)
GOOGLE_CALLBACK_URL=http://localhost:8000/auth/google/callback

# ── Google Analytics 4 (server-side tracking via Measurement Protocol) ──────
# Tracks: add_to_cart, remove_from_cart, add_shipping_info, add_payment_info, purchase
# Step 1: Create/open a GA4 property at https://analytics.google.com
# Step 2: Admin → Data Streams → your web stream → copy Measurement ID (G-XXXXXXXX)
# Step 3: Admin → Data Streams → your web stream → Measurement Protocol API secrets → Create
GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA_API_SECRET=

# ── Google Analytics 4 (Data API — admin dashboard reporting) ────────────────
# Required for the GA4 admin route at /app/ga4
# GA_PROPERTY_ID: numeric ID from your admin URL (…/pXXXXXXXXX/admin)
GA_PROPERTY_ID=
# GA_SERVICE_ACCOUNT_KEY: full JSON content of a Google Cloud Service Account key
# The service account must have "Viewer" access on this GA4 property.
# Steps: https://console.cloud.google.com/iam-admin/serviceaccounts → Create → Keys → JSON
# Then: GA4 Admin → Property Access Management → Add service account email as Viewer
GA_SERVICE_ACCOUNT_KEY=

# ── Digital Ocean Spaces (S3-compatible file storage) ──────────────────────────
# Get from: https://cloud.digitalocean.com/spaces
# Access Key ID (like AWS access key)
DO_SPACES_ACCESS_KEY_ID=
# Secret Access Key (like AWS secret key)
DO_SPACES_SECRET_ACCESS_KEY=
# Your space name (bucket name) in Digital Ocean
DO_SPACES_SPACE_NAME=
# Digital Ocean region code (e.g. nyc3, sfo3, sgp1, etc.)
DO_SPACES_REGION=
# Public URL endpoint for accessing files (e.g. https://your-space-name.nyc3.digitaloceanspaces.com)
DO_SPACES_ENDPOINT=